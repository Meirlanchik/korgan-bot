    }

    h1,
    h2 {
      margin: 0 0 12px;
      line-height: 1.2;
    }

    p {
      line-height: 1.5;
    }

    label {
      display: block;
      margin: 14px 0 6px;
      font-weight: 700;
    }

    input[type="text"],
    input[type="file"],
    select {
      width: 100%;
      box-sizing: border-box;
      padding: 10px 12px;
      border: 1px solid #b8c0cc;
      border-radius: 6px;
      font: inherit;
      background: #ffffff;
    }

    button,
    .button {
      display: inline-block;
      margin-top: 16px;
      padding: 10px 14px;
      border: 0;
      border-radius: 6px;
      color: #ffffff;
      background: #167347;
      font: inherit;
      text-decoration: none;
      cursor: pointer;
    }

    .inline-form {
      display: inline;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
    }

    code {
      display: inline-block;
      max-width: 100%;
      overflow-wrap: anywhere;
      padding: 3px 6px;
      border-radius: 4px;
      background: #eef2f7;
    }

    .message {
      border-color: #9ad0aa;
      background: #ecf9ef;
    }

    .error {
      border-color: #e7a0a0;
      background: #fff0f0;
    }

    dl {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 10px;
    }

    dt {
      font-weight: 700;
    }

    dd {
      margin: 0;
      overflow-wrap: anywhere;
    }

    @media (max-width: 640px) {
      dl {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>Kaspi прайс-лист</h1>
    <p>Загружай новый XML или Excel/CSV. Активная ссылка для Kaspi: <code>${escapeHtml(publicFeedUrl)}</code></p>
  </header>
  <main>
    ${message ? `<section class="message">${escapeHtml(message)}</section>` : ''}
    ${error ? `<section class="error">${escapeHtml(error)}</section>` : ''}

    <section>
      <h2>Текущий файл</h2>
      <dl>
        <dt>Статус</dt>
        <dd>${status.exists ? 'XML опубликован' : 'XML еще не загружен'}</dd>
        <dt>Товаров</dt>
        <dd>${status.offersCount}</dd>
        <dt>Компания</dt>
        <dd>${escapeHtml(status.company || '-')}</dd>
        <dt>Merchant ID</dt>
        <dd>${escapeHtml(status.merchantId || '-')}</dd>
        <dt>Обновлен</dt>
        <dd>${status.updatedAt ? escapeHtml(status.updatedAt) : '-'}</dd>
        <dt>Размер</dt>
        <dd>${status.size} байт</dd>
        <dt>Бот</dt>
        <dd>${botEnabled ? 'включен' : 'выключен, добавь TELEGRAM_BOT_TOKEN в .env'}</dd>
      </dl>
      <a class="button" href="/panel/products">Открыть товары</a>
      <a class="button" href="/panel/xml">Загрузить XML</a>
      <a class="button" href="/panel/download">Скачать XML</a>
      <form action="/panel/kaspi/download" method="post">
        <button type="submit">Скачать из Kaspi кабинета</button>
      </form>
      <form class="inline-form" action="/panel/kaspi/upload" method="post">
        <button type="submit">Загрузить XML в Kaspi</button>
      </form>
      <form class="inline-form" action="/panel/auto-pricing/run" method="post">
        <button type="submit">Запустить автопрайсинг</button>
      </form>
    </section>

    <form action="/panel/upload" method="post" enctype="multipart/form-data">
      <h2>Загрузить Excel/CSV</h2>

      <label for="company">Company</label>
      <input id="company" name="company" type="text" value="${escapeAttr(config.company)}">

      <label for="merchantId">Merchant ID</label>
      <input id="merchantId" name="merchantId" type="text" value="${escapeAttr(config.merchantId)}">

      <label for="storeIds">Склад Kaspi</label>
      <input id="storeIds" name="storeIds" type="text" value="${escapeAttr(config.storeIds.join(','))}">

      <label for="priceList">Файл</label>
      <input id="priceList" name="priceList" type="file" accept=".xlsx,.csv" required>

      <button type="submit">Загрузить</button>
    </form>

    <section>
      <h2>Колонки Excel/CSV</h2>
      <p><code>SKU</code>, <code>model</code>, <code>brand</code>, <code>price</code>, <code>PP1</code>, <code>PP2</code>, <code>PP3</code>, <code>PP4</code>, <code>PP5</code>, <code>preorder</code>.</p>
      <p>В PP-колонках можно писать остаток числом, <code>yes</code> или <code>no</code>. Для разных городов можно добавить колонки вида <code>cityprice_750000000</code>.</p>
    </section>
  </main>
</body>
</html>`;
}

function renderError(error) {
  return `<!doctype html>
<html lang="ru">
<head><meta charset="utf-8"><title>Ошибка</title></head>
<body>
  <h1>Ошибка</h1>
  <p>${escapeHtml(error.message)}</p>
  <p><a href="/panel/">Назад в панель</a></p>
</body>
</html>`;
}

function safeFileName(value) {
  return String(value).replace(/[^A-Za-z0-9._-]/g, '_');
}

function basicAuth(request, response, next) {
  const expectedUser = process.env.PANEL_USER;
  const expectedPassword = process.env.PANEL_PASSWORD;

  if (!expectedUser || !expectedPassword) {
    next();
    return;
  }

  const authorization = request.headers.authorization || '';
  const [scheme, encoded] = authorization.split(' ');

  if (scheme === 'Basic' && encoded) {
    const decoded = Buffer.from(encoded, 'base64').toString('utf8');
    const separator = decoded.indexOf(':');
    const user = separator >= 0 ? decoded.slice(0, separator) : '';
    const password = separator >= 0 ? decoded.slice(separator + 1) : '';

    if (user === expectedUser && password === expectedPassword) {
      next();
      return;
    }
  }

  response
    .set('WWW-Authenticate', 'Basic realm="Kaspi Panel"')
    .status(401)
    .send('Authentication required');
}

function delay(ms) {
  return new Promise((resolve) => {
    setTimeout(resolve, ms);
  });
}

function escapeHtml(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeAttr(value) {
  return escapeHtml(value);
}
